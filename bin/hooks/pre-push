#!/usr/bin/env bash
# pre-push: run bin/privacy-scan.sh over every commit about to leave this
# machine. This repo is public; the scan blocks real home paths, identities,
# secrets, endpoints (see CLAUDE.md "Public repository: no private data").
#
# Install once per clone (hooks are not copied by git clone):
#   git config core.hooksPath bin/hooks
#
# Stdin: one line per ref being pushed: <local ref> <local sha> <remote ref> <remote sha>
set -uo pipefail
repo="$(git rev-parse --show-toplevel)"
z40=0000000000000000000000000000000000000000
fail=0
while read -r _local_ref local_sha _remote_ref _remote_sha; do
  [ "$local_sha" = "$z40" ] && continue   # ref deletion: nothing outgoing
  # Every commit not already on some remote is outgoing. (A commit already
  # public on another remote is by definition already out.)
  for c in $(git -C "$repo" rev-list "$local_sha" --not --remotes 2>/dev/null); do
    if ! git -C "$repo" show "$c" | bash "$repo/bin/privacy-scan.sh"; then
      echo "pre-push: private data in commit $c — push aborted" >&2
      fail=1
    fi
  done
done
exit $fail
